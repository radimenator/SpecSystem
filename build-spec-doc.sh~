generate_html() {
  local JS_FILE="$HOME/SpecSystem/shared/pandoc/spec.js"

  pandoc "$OUTPUT_MD" \
    --standalone \
    --toc \
    --from markdown \
    --to html5 \
    --highlight-style pygments \
    --css "$CSS_FILE" \
    --include-in-header "$JS_FILE" \
    --metadata title="Specifikace projektu: $PROJECT_ID" \
    -o "$OUTPUT_HTML"

  echo "HTML vytvořen:"
  echo "  $OUTPUT_HTML"
}
