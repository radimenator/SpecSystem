:root {
  --bg: #ffffff;
  --text: #1f2937;
  --muted: #6b7280;
  --border: #e5e7eb;
  --panel: #f8fafc;
  --panel-2: #f3f4f6;
  --code-bg: #f7f7f8;
  --accent: #111827;
  --link: #2563eb;
}

html {
  font-size: 18px;
}

body {
  margin: 0;
  padding: 0;
  background: var(--bg);
  color: var(--text);
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif;
  line-height: 1.7;
}

main,
body > *:not(script):not(style) {
  box-sizing: border-box;
}

body {
  max-width: 980px;
  margin: 0 auto;
  padding: 48px 32px 80px;
}

h1, h2, h3, h4 {
  color: var(--accent);
  line-height: 1.2;
  margin-top: 2rem;
  margin-bottom: 0.8rem;
}

h1 {
  font-size: 2.2rem;
  margin-top: 0;
  padding-bottom: 0.4rem;
  border-bottom: 1px solid var(--border);
}

h2 {
  font-size: 1.6rem;
  margin-top: 2.4rem;
}

h3 {
  font-size: 1.2rem;
}

p {
  margin: 0.8rem 0;
}

ul, ol {
  margin: 0.6rem 0 1rem 1.3rem;
}

li {
  margin: 0.25rem 0;
}

a {
  color: var(--link);
  text-decoration: none;
}

a:hover {
  text-decoration: underline;
}

blockquote {
  margin: 1.2rem 0;
  padding: 0.9rem 1rem;
  border-left: 4px solid #cbd5e1;
  background: var(--panel);
  color: #334155;
  border-radius: 8px;
}

hr {
  border: 0;
  border-top: 1px solid var(--border);
  margin: 2rem 0;
}

code {
  font-family: "SFMono-Regular", SFMono-Regular, ui-monospace, Menlo, Consolas, monospace;
  font-size: 0.92em;
  background: var(--panel-2);
  padding: 0.15rem 0.35rem;
  border-radius: 6px;
}

pre {
  background: var(--code-bg);
  border: 1px solid var(--border);
  border-radius: 16px;
  padding: 18px 20px;
  overflow-x: auto;
  line-height: 1.55;
  box-shadow: 0 1px 2px rgba(0,0,0,0.04);
}

pre code {
  background: transparent;
  padding: 0;
  border-radius: 0;
  font-size: 0.95em;
}

div.sourceCode {
  margin: 1rem 0 1.4rem;
}

div.sourceCode pre {
  margin: 0;
}

table {
  width: 100%;
  border-collapse: collapse;
  margin: 1rem 0 1.4rem;
  font-size: 0.95rem;
}

th, td {
  border: 1px solid var(--border);
  padding: 10px 12px;
  text-align: left;
  vertical-align: top;
}

th {
  background: var(--panel);
}

nav#TOC,
nav[role="doc-toc"] {
  background: var(--panel);
  border: 1px solid var(--border);
  border-radius: 16px;
  padding: 18px 20px;
  margin: 1.5rem 0 2rem;
}

nav#TOC ul,
nav[role="doc-toc"] ul {
  margin-top: 0.5rem;
}

.header-section-number {
  color: var(--muted);
  margin-right: 0.35rem;
}

.title {
  margin-bottom: 0.3rem;
}

.date {
  color: var(--muted);
  margin-top: 0;
  margin-bottom: 2rem;
}

img {
  max-width: 100%;
  height: auto;
  border-radius: 14px;
  border: 1px solid var(--border);
}

@media print {
  body {
    max-width: none;
    padding: 24px;
    font-size: 12pt;
  }

  pre {
    white-space: pre-wrap;
    word-break: break-word;
  }

  h1, h2, h3 {
    page-break-after: avoid;
  }

  pre, blockquote, table {
    page-break-inside: avoid;
  }
}
