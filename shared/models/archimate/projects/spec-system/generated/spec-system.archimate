        </element>
        <element xsi:type="archimate:Plateau" name="SpecSystem v0.2" id="id-spec-system-v02">
          <documentation>Vrstvený systém evidence → wiki → SPEC → model.</documentation>
        </element>
        <element xsi:type="archimate:Plateau" name="SpecSystem v0.3" id="id-spec-system-v03">
          <documentation>Persistent memory layer a nightly rebuild workflow.</documentation>
        </element>
        <element xsi:type="archimate:WorkPackage" name="Persistent Memory Layer Project" id="id-persistent-memory-project">
          <documentation>Zavedení dlouhodobé memory vrstvy.</documentation>
        </element>
        <element xsi:type="archimate:WorkPackage" name="Open Exchange XML Generation" id="id-archimate-generation-project">
          <documentation>Generování ArchiMate Open Exchange XML modelů.</documentation>
        </element>
      </folder>
    </folder>
  </folder>
