  <folder name="Strategy" id="id-5fa5d0953d824c409cce5b6d1da8e519" type="strategy"/>
  <folder name="Business" id="id-ffcb40b8c14549d98283fef1ea742a7a" type="business">
    <folder name="Elements" id="id-304a319cf5ef483698aebbb149c74797">
      <folder name="business" id="id-80a5eab6755f4845aec0322f7ac089f4">
        <element xsi:type="archimate:BusinessService" name="SpecSystem" id="id-spec-system">
          <documentation>Kanonický systém pro správu specifikací a architektury.</documentation>
        </element>
        <element xsi:type="archimate:BusinessProcess" name="Specification Management" id="id-specification-management">
          <documentation>Správa životního cyklu specifikací.</documentation>
        </element>
        <element xsi:type="archimate:BusinessProcess" name="Architecture Modeling" id="id-architecture-modeling">
          <documentation>Modelování architektury pomocí ArchiMate.</documentation>
        </element>
        <element xsi:type="archimate:BusinessProcess" name="Document Generation" id="id-document-generation">
          <documentation>Generování formálních dokumentů a výstupů.</documentation>
        </element>
        <element xsi:type="archimate:BusinessProcess" name="Memory Rebuild" id="id-memory-rebuild-process">
          <documentation>Periodický rebuild persistentní memory.</documentation>
        </element>
      </folder>
    </folder>
  </folder>
  <folder name="Application" id="id-e24e02a9e3614b27808f2628b270211b" type="application">
    <folder name="Elements" id="id-5b8c16e8d6d54b45a61c15fef81614a6">
      <folder name="application" id="id-48fcc909f1524988918c06762329c365">
        <element xsi:type="archimate:ApplicationComponent" name="Roam Research" id="id-roam-research">
          <documentation>Prostředí pro poznámky, myšlení a projektový kontext.</documentation>
        </element>
        <element xsi:type="archimate:ApplicationComponent" name="Source Evidence Repository" id="id-source-evidence-repository">
          <documentation>Úložiště zdrojových dokumentů a evidence.</documentation>
        </element>
        <element xsi:type="archimate:ApplicationComponent" name="Obsidian / LLM Wiki" id="id-llm-wiki">
          <documentation>Interpretační a znalostní vrstva systému.</documentation>
        </element>
        <element xsi:type="archimate:ApplicationComponent" name="Persistent Memory Layer" id="id-persistent-memory-layer">
          <documentation>Dlouhodobá pracovní paměť pro LLM a agenty.</documentation>
        </element>
        <element xsi:type="archimate:ApplicationComponent" name="ArchiMate Model Repository" id="id-archimate-model-repository">
          <documentation>Formální architektonický model systému.</documentation>
        </element>
        <element xsi:type="archimate:ApplicationComponent" name="Output Generation Layer" id="id-output-generation-layer">
          <documentation>Generování OHA, PDF, DOCX a dalších výstupů.</documentation>
        </element>
        <element xsi:type="archimate:ApplicationComponent" name="Local LLM" id="id-local-llm">
          <documentation>Lokální LLM běžící přes Ollama.</documentation>
        </element>
        <element xsi:type="archimate:ApplicationComponent" name="OpenClaw" id="id-openclaw">
          <documentation>Agent orchestration a workflow systém.</documentation>
        </element>
        <element xsi:type="archimate:ApplicationComponent" name="Ollama" id="id-ollama">
          <documentation>Runtime pro lokální LLM modely.</documentation>
        </element>
        <element xsi:type="archimate:ApplicationComponent" name="Qwen 2.5 14B" id="id-qwen-14b">
          <documentation>Lokální reasoning model.</documentation>
        </element>
        <element xsi:type="archimate:ApplicationComponent" name="Nomic Embed Text" id="id-nomic-embed-text">
          <documentation>Embedding model pro retrieval a indexing.</documentation>
        </element>
        <element xsi:type="archimate:ApplicationComponent" name="~/Projects" id="id-implementation-projects">
          <documentation>Lokální adresář s implementací, kódem a generovanými artefakty.</documentation>
        </element>
        <element xsi:type="archimate:DataObject" name="SPEC Files" id="id-spec-files">
          <documentation>Kanonické specifikační soubory projektu.</documentation>
        </element>
        <element xsi:type="archimate:DataObject" name="Memory Files" id="id-memory-files">
          <documentation>Persistentní znalostní extrakty.</documentation>
        </element>
        <element xsi:type="archimate:DataObject" name="Wiki Pages" id="id-wiki-pages">
          <documentation>Generované wiki stránky.</documentation>
        </element>
        <element xsi:type="archimate:DataObject" name="Open Exchange XML" id="id-archimate-open-exchange">
          <documentation>Exportovaný ArchiMate model.</documentation>
        </element>
      </folder>
    </folder>
  </folder>
  <folder name="Technology &amp; Physical" id="id-d299fc41eec149d592a1255005ec8586" type="technology">
    <folder name="Elements" id="id-ea5695a839ab457792c23475aa01931a">
      <folder name="technology" id="id-416e983bd009491c9ed274d59cbd596d">
        <element xsi:type="archimate:Node" name="MacBook Local Environment" id="id-macbook-local">
          <documentation>Lokální pracovní prostředí.</documentation>
        </element>
        <element xsi:type="archimate:Node" name="Hetzner VPS" id="id-hetzner-vps">
          <documentation>Vzdálené automatizační prostředí.</documentation>
        </element>
        <element xsi:type="archimate:SystemSoftware" name="Git Repository" id="id-git-repository">
          <documentation>Verzování SPEC, memory a modelů.</documentation>
        </element>
        <element xsi:type="archimate:TechnologyService" name="Nightly Rebuild Service" id="id-cron-nightly-rebuild">
          <documentation>Automatizovaný rebuild memory a wiki.</documentation>
        </element>
      </folder>
    </folder>
  </folder>
  <folder name="Motivation" id="id-28fcc2885609485dab6f02097573ae34" type="motivation">
    <folder name="Elements" id="id-70ab0569e9ee49da8f35ea46dad70701">
      <folder name="motivation" id="id-c8a953d99951459faea3af74dde29c6d">
        <element xsi:type="archimate:Stakeholder" name="Radim Pokorný" id="id-radim-pokorny">
          <documentation>Autor a hlavní architekt systému SpecSystem.</documentation>
        </element>
        <element xsi:type="archimate:Stakeholder" name="OpenClaw Agents" id="id-openclaw-agents">
          <documentation>Agentní infrastruktura využívající SPEC, memory a workflow.</documentation>
        </element>
        <element xsi:type="archimate:Driver" name="Traceability" id="id-spec-system-driver-traceability">
          <documentation>Potřeba dohledatelnosti všech rozhodnutí, modelů a výstupů.</documentation>
        </element>
        <element xsi:type="archimate:Driver" name="Single Source of Truth" id="id-spec-system-driver-source-of-truth">
          <documentation>Potřeba jediné kanonické specifikace systému.</documentation>
        </element>
        <element xsi:type="archimate:Assessment" name="Fragmented Documentation" id="id-spec-system-assessment-fragmentation">
          <documentation>Dokumentace a znalosti bývají roztříštěné mezi více systémů.</documentation>
        </element>
        <element xsi:type="archimate:Goal" name="Canonical Specification" id="id-spec-system-goal-canonical-spec">
          <documentation>Vytvořit stabilní kanonickou specifikaci projektů.</documentation>
        </element>
        <element xsi:type="archimate:Goal" name="Deterministic Regeneration" id="id-spec-system-goal-regeneration">
          <documentation>Umožnit regeneraci dokumentace a modelů ze specifikace.</documentation>
        </element>
        <element xsi:type="archimate:Requirement" name="Persistent Memory Layer" id="id-spec-system-requirement-memory">
          <documentation>Systém musí obsahovat dlouhodobou pracovní memory vrstvu.</documentation>
        </element>
        <element xsi:type="archimate:Requirement" name="Local LLM Support" id="id-spec-system-requirement-local-llm">
          <documentation>Systém musí podporovat běh lokálních LLM modelů.</documentation>
        </element>
        <element xsi:type="archimate:Constraint" name="Local First" id="id-spec-system-constraint-local-first">
          <documentation>Citlivá data musí zůstávat lokálně.</documentation>
        </element>
        <element xsi:type="archimate:Constraint" name="Human Approval Required" id="id-spec-system-constraint-human-approval">
          <documentation>LLM nesmí měnit SPEC bez potvrzení člověkem.</documentation>
        </element>
        <element xsi:type="archimate:Principle" name="SPEC is Source of Truth" id="id-spec-system-principle-spec-authority">
          <documentation>SPEC je jediná autoritativní pravda systému.</documentation>
        </element>
        <element xsi:type="archimate:Principle" name="Memory is not SPEC" id="id-spec-system-principle-memory-separation">
          <documentation>Persistent memory není kanonická specifikace.</documentation>
        </element>
      </folder>
    </folder>
  </folder>
  <folder name="Implementation &amp; Migration" id="id-cfd043f2d72b43f7a8fa3bb0f888f328" type="implementation_migration">
