{
    "entity": "es_application",
    "schemaVersion": "1.0",
    "template": {
        "id": "es_application",
        "title": "Aplikace",
        "layer": "elementary",
        "description": "Šablona elementární služby typu Aplikace provozovaná nad sdílenou platformou nebo prostředím.",
        "parameters": [
            {
                "name": "template_id",
                "label": "ID šablony aplikace",
                "type": "text",
                "required": true
            },
            {
                "name": "template_name",
                "label": "Název šablony aplikace",
                "type": "text",
                "required": true
            },
            {
                "name": "application_code",
                "label": "Kód aplikace",
                "type": "text",
                "required": true
            },
            {
                "name": "application_name",
                "label": "Název aplikace",
                "type": "text",
                "required": true
            },
            {
                "name": "application_type",
                "label": "Typ aplikace",
                "type": "select",
                "options": [
                    "web",
                    "api",
                    "batch",
                    "desktop",
                    "integration",
                    "database_client",
                    "mixed"
                ]
            },
            {
                "name": "environment_type",
                "label": "Typ prostředí",
                "type": "select",
                "options": [
                    "dev",
                    "test",
                    "stage",
                    "prod"
                ]
            },
            {
                "name": "runtime_type",
