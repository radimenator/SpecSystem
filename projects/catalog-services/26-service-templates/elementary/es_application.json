                "type": "select",
                "options": [
                    "none",
                    "source_nat",
                    "destination_nat",
                    "both"
                ]
            },
            {
                "name": "monitoring_need",
                "label": "Potřeba monitoringu",
                "type": "select",
                "options": [
                    "none",
                    "basic",
                    "standard",
                    "enhanced"
                ]
            },
            {
                "name": "logging_need",
                "label": "Potřeba logování",
                "type": "select",
                "options": [
                    "none",
                    "basic",
                    "standard",
                    "audit"
                ]
            },
            {
                "name": "backup_need",
                "label": "Potřeba zálohování",
                "type": "select",
                "options": [
                    "none",
                    "standard",
                    "enhanced",
                    "critical"
                ]
            },
            {
                "name": "lifecycle_status",
                "label": "Lifecycle status",
                "type": "select",
                "options": [
                    "draft",
                    "active",
                    "deprecated",
                    "retired"
                ]
            },
            {
                "name": "pricing_model",
                "label": "Pricing model",
                "type": "select",
                "options": [
                    "fixed",
                    "per_application",
                    "resource_based"
                ]
            }
