                "options": [
                    "vm",
                    "container",
                    "baremetal",
                    "mixed"
                ]
            },
            {
                "name": "server_count",
                "label": "Počet serverů / instancí",
                "type": "number"
            },
            {
                "name": "tenant",
                "label": "Tenant",
                "type": "text"
            },
            {
                "name": "vrf",
                "label": "VRF",
                "type": "text"
            },
            {
                "name": "network_segment",
                "label": "Síťový segment",
                "type": "text"
            },
            {
