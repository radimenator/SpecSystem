{
    "entity": "es_application",
    "schemaVersion": "1.0",
    "template": {
        "id": "es_application",
        "title": "Aplikace",
        "layer": "elementary",
        "description": "Šablona elementární služby typu Aplikace. Aplikace je atomický workload bez runtime závislostí na jiných ES/AG službách.",
        "parameters": [
            {
                "name": "template_id",
                "label": "ID šablony aplikace",
                "type": "text",
                "required": true
            },
            {
                "name": "template_name",
                "label": "Název šablony aplikace",
                "type": "text",
                "required": true
            },
            {
                "name": "application_type",
                "label": "Typ aplikace",
                "type": "select",
                "options": [
                    "web",
                    "api",
                    "batch",
                    "desktop",
                    "integration",
                    "mixed"
                ]
            },
            {
                "name": "access_channel",
                "label": "Přístupový kanál",
                "type": "multi_select",
                "options": [
                    "internal_web",
                    "external_web",
                    "api",
                    "remote_desktop",
                    "machine_to_machine"
                ]
            },
            {
                "name": "runtime_model",
                "label": "Runtime model",
                "type": "select",
                "options": [
                    "vm",
                    "container",
                    "baremetal",
                    "managed_platform",
                    "unspecified"
                ]
            },
            {
                "name": "deployment_size",
                "label": "Velikost nasazení",
                "type": "select",
                "options": [
                    "small",
                    "medium",
                    "large",
                    "enterprise"
                ]
            }
        ],
        "operations": [
            {
                "name": "application_runtime_support",
                "label": "podpora běhu aplikace"
            },
            {
                "name": "application_configuration_support",
                "label": "podpora konfigurace aplikace"
            },
            {
                "name": "release_coordination",
                "label": "koordinace releasů"
            },
            {
                "name": "monitoring_coordination",
                "label": "koordinace monitoringu"
            },
            {
                "name": "logging_coordination",
                "label": "koordinace logování"
            },
            {
                "name": "backup_coordination",
                "label": "koordinace zálohování"
            },
            {
                "name": "incident_tracking",
                "label": "řešení a evidence incidentů"
            }
        ],
        "pricing": [
            {
                "name": "base_monthly_price",
                "label": "základní měsíční cena",
                "type": "number"
            },
            {
                "name": "runtime_support_price",
                "label": "podpora běhu aplikace",
                "type": "number"
            },
            {
                "name": "configuration_support_price",
                "label": "podpora konfigurace",
                "type": "number"
            },
            {
                "name": "release_coordination_price",
                "label": "koordinace releasů",
                "type": "number"
            },
            {
                "name": "monitoring_coordination_price",
                "label": "koordinace monitoringu",
                "type": "number"
            },
            {
                "name": "logging_coordination_price",
                "label": "koordinace logování",
                "type": "number"
            },
            {
                "name": "backup_coordination_price",
                "label": "koordinace zálohování",
                "type": "number"
            },
            {
                "name": "incident_support_price",
                "label": "podpora incidentů",
                "type": "number"
            },
            {
                "name": "maintenance_price",
                "label": "maintenance cena",
                "type": "number"
            },
            {
                "name": "support_price",
                "label": "support cena",
                "type": "number"
            }
        ]
    }
}