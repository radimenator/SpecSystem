        "description": "Šablona agregační služby typu Aplikace provozovaná nad sdílenou infrastrukturou, například UPAAS.",
        "parameters": [
            {
                "name": "template_id",
                "label": "ID šablony aplikace",
                "type": "text",
                "required": true
            },
            {
                "name": "template_name",
                "label": "Název šablony aplikace",
                "type": "text",
                "required": true
            },
            {
                "name": "application_code",
                "label": "Kód aplikace",
                "type": "text",
                "required": true
            },
            {
                "name": "application_name",
                "label": "Název aplikace",
                "type": "text",
                "required": true
            },
            {
                "name": "environment",
                "label": "Prostředí",
                "type": "select",
                "required": true,
                "options": [
                    "test",
                    "prod",
                    "dev",
                    "stage"
                ]
            },
            {
                "name": "tenant",
                "label": "Tenant",
